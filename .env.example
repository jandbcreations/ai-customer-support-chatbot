# Copy this file to ".env" (or ".env.local") and fill in your key.
# Both are gitignored; .env.local takes precedence if both exist. Never commit a real key.

# OPTIONAL: with no key set, the bot runs in offline MOCK MODE — every feature is
# fully testable without an API key. Add a key here to use the live Claude model.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: model to use. Defaults to a fast, low-cost model well-suited to support replies.
# Bump to claude-sonnet-4-6 if you want richer reasoning at higher cost.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: force a mode regardless of the key. "mock" = offline engine,
# "anthropic" = live model. Leave unset to auto-detect from the key above.
# CHAT_MODE=mock

# Optional: port for the web UI (defaults to 3000)
PORT=3000
