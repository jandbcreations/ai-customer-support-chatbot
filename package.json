{
  "name": "north-star-support-bot",
  "version": "1.0.0",
  "description": "Custom LLM customer-support chatbot for North Star Outfitters (outdoor apparel & camping gear): order tracking, returns/exchanges, product recommendations, human handoff.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "cli": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "chatbot",
    "customer-support",
    "llm",
    "anthropic",
    "claude",
    "tool-use",
    "function-calling"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
